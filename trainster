function buildExport(session) {
  const lines = [];
  lines.push(`TRAININGS-LOG — ${session.dateISO.slice(0, 10)}`);
  lines.push(`${session.planName} · ${session.dayName}`);
  const vol = session.entries.reduce((a, e) => a + volumeOf(e), 0);
  lines.push(`Gesamtvolumen: ${vol.toLocaleString("de-DE")} kg`);
  lines.push("");
  session.entries.forEach(e => {
    if (e.type === "duration") {
      const el = e.actual.seconds != null ? e.actual.seconds : (e.actual.minutes || 0) * 60;
      const diff = el - e.target.minutes * 60;
      const status = e.actual.done ? "GESCHAFFT" : diff < 0 ? "VERFEHLT (zu kurz)" : "VERFEHLT (zu lang)";
