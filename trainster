/* Migration: altes day.name -> neues day.label (Nummer/Präfix wird abgestreift). */
function migratePlan(p) {
  if (!p || !Array.isArray(p.days)) return p;
  return {
    ...p,
    restCompound: p.restCompound != null ? p.restCompound : 90,
    restIsolation: p.restIsolation != null ? p.restIsolation : 60,
    exRest: p.exRest != null ? p.exRest : 120,
    days: p.days.map(d => {
      let label = d.label;
      if (label === undefined) {
        const raw = typeof d.name === "string" ? d.name : "";
        label = raw.replace(/^\s*(?:Einheit|Tag)\s*\d+\s*(?:[·:–\-]\s*)?/i, "").trim();
      }
      const {
        name,
        ...rest
      } = d;
      const exercises = Array.isArray(d.exercises) ? d.exercises.map(e => (e.type === "strength" || e.type === "hold") && !e.category ? {
        ...e,
        category: e.type === "hold" ? "isolation" : "compound"
      } : e) : d.exercises;
      return {
        ...rest,
        exercises,
        label: label || ""
      };
    })
  };
}

