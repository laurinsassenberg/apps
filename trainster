/* ============================================================
   STORAGE
   ============================================================ */
async function sGet(key) {
  try {
    const r = await window.storage.get(key);
    return r ? JSON.parse(r.value) : null;
  } catch {
    return null;
  }
}
async function sSet(key, val) {
  try {
    await window.storage.set(key, JSON.stringify(val));
  } catch {}
}
async function sDel(key) {
  try {
    await window.storage.delete(key);
  } catch {}
}

/* ============================================================
   LOGIK
   ============================================================ */
function evalStrength(ex, sets) {
  const statuses = sets.map(s => {
    const r = Number(s.reps) || 0;
    return r >= ex.repsMax ? 2 : r >= ex.repsMin ? 1 : 0;
  });
  const min = Math.min(...statuses);
  let res = min === 0 ? "verfehlt" : min === 2 ? "uebertroffen" : "erreicht";
  const avgW = sets.reduce((a, s) => a + (Number(s.weight) || 0), 0) / sets.length;
  if (avgW > (ex.weight || 0) && min >= 1) res = "uebertroffen";
  return res;
}
function evalHold(ex, sets) {
  const min = Math.min(...sets.map(s => Number(s.seconds) || 0));
  return min >= ex.seconds * 1.15 ? "uebertroffen" : min >= ex.seconds ? "erreicht" : "verfehlt";
}
function volumeOf(entry) {
  if (entry.type !== "strength") return 0;
  return entry.actual.reduce((a, s) => a + (Number(s.reps) || 0) * (Number(s.weight) || 0), 0);
}

/* Effort pro Satz (Nähe zum Versagen, RIR-basiert).
   base = Reizintensität auf der Sweet-Spot-Achse: leicht < fordernd (Optimum) < limit (zu viel) */
const EFFORT = {
  leicht: {
    label: "Locker",
    sub: "noch einiges drin",
    color: C.muted,
    base: 30
  },
  fordernd: {
    label: "Fordernd",
    sub: "1–2 raus",
    color: C.mint,
    base: 85
  },
  limit: {
    label: "Am Limit",
    sub: "alles gegeben",
    color: C.clay,
    base: 96
  }
};
const EFFORT_ORDER = ["leicht", "fordernd", "limit"];

/* Reizintensität (0–100). Optimum-Fenster 80–92; Effort als Haupttreiber, Korridor korrigiert leicht. */
function scoreStrengthSet(ex, s) {
  let v = (EFFORT[s.effort] || EFFORT.fordernd).base;
  const r = Number(s.reps) || 0;
  if (r > ex.repsMax) v -= 8; // mehr als Korridor geschafft → war leichter als angegeben
  else if (r < ex.repsMin) v += 4; // unter Korridor → näher am Limit
  return Math.max(0, Math.min(100, v));
}
function scoreStrength(ex, sets) {
  if (!sets.length) return 0;
  return Math.round(sets.reduce((a, s) => a + scoreStrengthSet(ex, s), 0) / sets.length);
}
function scoreHold(ex, sets) {
  if (!sets.length) return 0;
  return Math.round(sets.reduce((a, s) => a + (EFFORT[s.effort] || EFFORT.fordernd).base, 0) / sets.length);
}
const evalFromScore = s => s < 50 ? "verfehlt" : s >= 80 && s <= 92 ? "uebertroffen" : "erreicht";
function stimulus(score) {
  if (score < 50) return {
    label: "Reiz zu gering",
    color: C.clay,
    hint: "Zu locker — für Wachstum näher ans Limit (etwa 1–2 Wdh. vor dem Versagen)."
  };
  if (score < 80) return {
    label: "Solide",
    color: C.gold,
    hint: "Ordentlicher Reiz. Etwas näher ans Limit geht noch."
  };
  if (score <= 92) return {
    label: "Optimaler Reiz",
    color: C.mint,
    hint: "Im Sweet Spot — wenn die Wdh. oben im Korridor rauskommen, Gewicht erhöhen."
  };
  return {
    label: "Sehr hart",
    color: C.gold,
    hint: "Maximal nah am Versagen. Effektiv, aber kostet viel Erholung — nicht jeder Satz muss bis zum Limit."
  };
}

/* Cardio/Dauer: Zeitformat + Bewertung (zu kurz / im Fenster bis +5 min / zu lang) */
const DURATION_TOLERANCE = 300; // Sekunden über Soll, die noch als geschafft gelten
function fmtDur(sec) {
  sec = Math.round(Math.abs(sec));
  if (sec < 60) return `${sec} Sek`;
  const m = Math.floor(sec / 60),
    s = sec % 60;
  return s ? `${m}:${String(s).padStart(2, "0")} min` : `${m} min`;
}
function durationResult(targetMin, elapsedSec) {
  const targetSec = targetMin * 60;
  const el = Math.max(0, Math.round(elapsedSec || 0));
  const diff = el - targetSec; // >0 drüber, <0 drunter
  const ok = el >= targetSec && diff <= DURATION_TOLERANCE;
  let sub;
  if (diff === 0) sub = "punktgenau getroffen";else if (diff < 0) sub = `Soll um ${fmtDur(diff)} verfehlt`;else if (ok) sub = `Soll um ${fmtDur(diff)} übertroffen`;else sub = `Soll um ${fmtDur(diff)} überschritten — zu lang`;
  return {
    ok,
    diff,
    elapsedSec: el,
    sub
  };
}
